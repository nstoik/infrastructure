          type: unifi
          url: https://unifi.home.stechsolutions.ca
          username: HomepageUser
          password: "{{  secret_unifi_username_password}}"
    - Unifi Protect:
        href: https://unifi.home.stechsolutions.ca/protect/dashboard
        description: Unifi Protect
        icon: unifi-protect.png
- Proxmox:
    - Proxmox VE:
        href: https://pve3.home.stechsolutions.ca:8006
        description: Proxmox VE
        siteMonitor: https://pve3.home.stechsolutions.ca:8006
        icon: proxmox.png
        widget:
          type: proxmox
          url: https://pve3.home.stechsolutions.ca:8006
          username: homepage@pve!homepage
          password: "{{ secret_pve_homepage_token }}"
    - Proxmox Backup Server:
        href: https://pbs.home.stechsolutions.ca:8007
        description: Proxmox Backup Server
        siteMonitor: https://pbs.home.stechsolutions.ca:8007
        icon: proxmox.png
        widget:
          type: proxmoxbackupserver
          url: https://pbs.home.stechsolutions.ca:8007
          username: homepage@pbs!homepage
          password: "{{ secret_pbs_homepage_token }}"
- Proxy:
    - NelsonPlex:
        href: https://media.stechsolutions.ca
        description: External dashhboard page
        siteMonitor: https://media.stechsolutions.ca
        icon: mdi-monitor-dashboard
- Media Playback:
    - Watch Time Today:
        description: NelsonPlex total time watched today
        icon: mdi-counter
        widgets:
            - type: customapi
              url: https://tautulli.home.stechsolutions.ca/api/v2?cmd=get_plays_by_date&time_range=1&y_axis=duration&apikey={{ secret_tautulli_api_key }}
              method: GET
              refreshInterval: 60000
              mappings:
                - label: Total Watch Time
                  # navigate into the series array to get the 'Total' entry
                  field: response.data.series[4].data
                  format: duration
- Storage:
    - Movies:
        description: Movies dataset
        icon: mdi-filmstrip
        widgets:
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(node_filesystem_size_bytes%7Binstance%3D%22storage.home.stechsolutions.ca:9100%22%2Cmountpoint%3D%22%2Fmnt%2Fzfs%2Fstorage3%2Fmovies%22%7D)
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Total Capacity
                  field: data.result.1
                  format: bytes
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(node_filesystem_size_bytes%7Binstance%3D%22storage.home.stechsolutions.ca:9100%22%2Cmountpoint%3D%22%2Fmnt%2Fzfs%2Fstorage3%2Fmovies%22%7D-node_filesystem_avail_bytes%7Binstance%3D%22storage.home.stechsolutions.ca:9100%22%2Cmountpoint%3D%22%2Fmnt%2Fzfs%2Fstorage3%2Fmovies%22%7D)
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Used
                  field: data.result.1
                  format: bytes
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(round(increase(node_zfs_zpool_dataset_nwritten%7Bdataset%3D%22storage3%2Fmovies%22%7D%5B24h%5D)))
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Written (24h)
                  field: data.result.1
                  format: bytes
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(round(increase(node_zfs_zpool_dataset_nread%7Bdataset%3D%22storage3%2Fmovies%22%7D%5B24h%5D)))
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Read (24h)
                  field: data.result.1
                  format: bytes
