        proxmoxVMID: 101
        proxmoxType: lxc
        widget:
          type: pihole
          url: https://pihole-2.home.stechsolutions.ca
          version: 6
          key: "{{ secret_pihole_app_password }}"
    - Unifi OS:
        href: https://unifi.home.stechsolutions.ca
        description: Unifi OS
        icon: unifi.png
    - Unifi Controller:
        href: https://unifi.home.stechsolutions.ca/network/default/dashboard
        description: Unifi Controller
        icon: unifi-controller.png
