---
- Requests:
    - Ombi:
        description: Media Requests
        icon: ombi.png
        href: https://media.stechsolutions.ca/ombi
- Services:
    - Wrapperr:
        description: Plex Wrapped
        icon: plex-rewind.png
        href: https://media.stechsolutions.ca/wrapperr
- Media Playback:
    - Plex:
        description: Plex Media Server
        icon: plex.png
        href: https://app.plex.tv/desktop/#!/
        widget:
          type: plex
          url: http://10.10.5.24:32400
          key: "{{ secret_plex_api_key }}"
          fields: ["movies","tv"]
- Status:
    - Uptime:
        description: Click to view the uptime status page
        icon: uptime-kuma.png
        href: https://uptime.stechsolutions.ca/status/nelsonplex
    - Current Activity:
        description: Current NelsonPlex server activity
        icon: plex.png
        widgets:
            - type: customapi
              url: https://tautulli.home.stechsolutions.ca/api/v2?apikey={{ secret_tautulli_api_key }}&cmd=get_activity
              refreshInterval: 5000
              method: GET
              mappings:
                - label: Watching
                  field: response.data.stream_count
                  format: number
                - label: Bandwidth
                  field: response.data.total_bandwidth
                  format: bitrate
                  scale: 1000
    - Watch Time Today:
        description: NelsonPlex total time watched today
        icon: mdi-counter
        widgets:
            - type: customapi
              url: https://tautulli.home.stechsolutions.ca/api/v2?cmd=get_plays_by_date&time_range=1&y_axis=duration&apikey={{ secret_tautulli_api_key }}
              method: GET
              refreshInterval: 60000
              mappings:
                - label: Total Watch Time
                  # navigate into the series array to get the 'Total' entry
                  field: response.data.series[4].data
                  format: duration
- Storage:
    - Movies:
        description: Movies dataset
        icon: mdi-filmstrip
        widgets:
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(node_filesystem_size_bytes%7Binstance%3D%22storage.home.stechsolutions.ca:9100%22%2Cmountpoint%3D%22%2Fmnt%2Fzfs%2Fstorage3%2Fmovies%22%7D)
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Total Capacity
                  field: data.result.1
                  format: bytes
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(node_filesystem_size_bytes%7Binstance%3D%22storage.home.stechsolutions.ca:9100%22%2Cmountpoint%3D%22%2Fmnt%2Fzfs%2Fstorage3%2Fmovies%22%7D-node_filesystem_avail_bytes%7Binstance%3D%22storage.home.stechsolutions.ca:9100%22%2Cmountpoint%3D%22%2Fmnt%2Fzfs%2Fstorage3%2Fmovies%22%7D)
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Used
                  field: data.result.1
                  format: bytes
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(round(increase(node_zfs_zpool_dataset_nwritten%7Bdataset%3D%22storage3%2Fmovies%22%2Cinstance%3D%22storage.home.stechsolutions.ca:9100%22%7D%5B24h%5D)))
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Written (24h)
                  field: data.result.1
                  format: bytes
            - type: customapi
              url: https://prometheus.home.stechsolutions.ca/api/v1/query?query=scalar(round(increase(node_zfs_zpool_dataset_nread%7Bdataset%3D%22storage3%2Fmovies%22%2Cinstance%3D%22storage.home.stechsolutions.ca:9100%22%7D%5B24h%5D)))
              method: GET
              display: list
              refreshInterval: 300000
              mappings:
                - label: Read (24h)
                  field: data.result.1
                  format: bytes
