---
name: tools

services:
  it-tools:
    image: corentinth/it-tools:2024.10.22-7ca5933
    container_name: it-tools
    networks:
      - traefik
    restart: unless-stopped
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.it-tools.rule=Host(`it-tools.home.stechsolutions.ca`)"
      - "traefik.docker.network=traefik"
      - "traefik.http.services.it-tools.loadbalancer.server.port=80"
      - "traefik.http.routers.it-tools.entrypoints=websecure"
      - "traefik.http.routers.it-tools.tls.certresolver=letsencrypt"
      - "homepage.group=Developer Tools"
      - "homepage.name=IT-Tools"
      - "homepage.description=IT-Tools"
      - "homepage.icon=it-tools.png"
      - "homepage.href=https://it-tools.home.stechsolutions.ca"
      - "homepage.siteMonitor=https://it-tools.home.stechsolutions.ca"
      - "wud.tag.include=^\\d{4}\\.\\d+\\.\\d+(?:-[0-9a-f]+)?$"
      - "wud.link.template=https://hub.docker.com/r/corentinth/it-tools/tags"

  stirling-pdf:
    image: stirlingtools/stirling-pdf:2.7.3
    container_name: stirling-pdf
    networks:
      - traefik
    volumes:
      - /home/{{ default_user }}/docker_mounts/tools/stirling-pdf/configs:/configs
    restart: unless-stopped
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.stirling-pdf.rule=Host(`stirling-pdf.home.stechsolutions.ca`)"
      - "traefik.docker.network=traefik"
      - "traefik.http.services.stirling-pdf.loadbalancer.server.port=8080"
      - "traefik.http.routers.stirling-pdf.entrypoints=websecure"
      - "traefik.http.routers.stirling-pdf.tls.certresolver=letsencrypt"
      - "homepage.group=Files"
      - "homepage.name=Stirling PDF"
      - "homepage.description=PDF manipulation tool"
      - "homepage.icon=stirling-pdf.png"
      - "homepage.href=https://stirling-pdf.home.stechsolutions.ca"
      - "homepage.siteMonitor=https://stirling-pdf.home.stechsolutions.ca"
      - "wud.tag.include=^\\d+\\.\\d+\\.\\d+$"
      - "wud.link.template=https://hub.docker.com/r/stirlingtools/stirling-pdf/tags"

networks:
  traefik:
    name: traefik
    external: true
